{
  "name": "src",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "create:immersive-scene": "node scripts/create-immersive-scene.mjs",
    "create:minigame": "node scripts/create-minigame.mjs",
    "create:room-scene": "node scripts/create-room-scene.mjs",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\"",
    "precommit:check": "node scripts/precommit-check.cjs",
    "preview": "vite preview",
    "test": "node --test tests/template/*.test.mjs tests/room/*.test.mjs tests/room-template/*.test.mjs tests/minigame-template/*.test.mjs",
    "test:minigame-template": "node --test tests/minigame-template/*.test.mjs",
    "test:room": "node --test tests/room/*.test.mjs",
    "test:template": "node --test tests/template/*.test.mjs",
    "test:room-template": "node --test tests/room-template/*.test.mjs"
  },
  "dependencies": {
    "@react-three/drei": "^10.0.0",
    "@react-three/fiber": "^9.1.0",
    "gsap": "^3.12.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "three": "^0.175.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.175.0",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsdoc": "^61.7.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "prettier": "^3.8.1",
    "terser": "^5.46.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1"
  }
}
